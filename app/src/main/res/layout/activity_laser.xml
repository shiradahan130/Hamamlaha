<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- כפתור חזרה -->
        <Button
            android:id="@+id/goBack"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:layout_marginStart="8dp"
            android:layout_gravity="start"
            android:backgroundTint="@android:color/transparent"
            android:textColor="#ff0084"
            android:fontFamily="@font/asakimboldwebfont"
            android:textSize="20dp"
            android:text="➜" />

        <!-- כותרת -->
        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/asakimboldwebfont"
            android:gravity="center"
            android:text="לייזר"
            android:textColor="#ff0084"
            android:textSize="45sp"
            android:textStyle="bold" />

        <!-- קרוסלה -->
        <androidx.viewpager2.widget.ViewPager2
            android:id="@+id/viewPager"
            android:layout_width="match_parent"
            android:layout_height="260dp"
            android:layout_marginTop="20dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:paddingStart="40dp"
            android:paddingEnd="40dp" />

        <!-- טקסט אינסטגרם -->
        <TextView
            android:id="@+id/textView0"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:fontFamily="@font/asakimboldwebfont"
            android:gravity="center"
            android:text="לתמונות ומידע נוסף היכנסו לאינסטגרם של הממלכה"
            android:textColor="#ff0084"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textView43"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/asakimboldwebfont"
            android:gravity="center"
            android:text="כך תישארו מעודכנים ותראו איך הקסם קורה !"
            android:textColor="#ff0084"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- אייקון אינסטגרם -->
        <ImageView
            android:id="@+id/instagramBtn"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginTop="12dp"
            android:src="@drawable/instagram_icon" />

        <TextView
            android:id="@+id/textView7"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/playitalic"
            android:gravity="center"
            android:text="hamamlaha_eilat"
            android:textColor="@color/black"
            android:textSize="10sp"
            android:textStyle="bold" />

        <!-- פס ורוד תחתון -->
        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="200dp"
            android:background="#ff0084" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>