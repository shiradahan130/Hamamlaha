<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@android:color/white">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="התורים שלי"
        android:textSize="37sp"
        android:fontFamily="@font/nootaj"
        android:gravity="center"
        android:padding="16dp"
        android:textColor="?attr/colorOnSurface"/>

    <TextView
        android:id="@+id/tv_appointment_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginStart="16dp"
        android:layout_marginBottom="8dp"
        android:text="מספר תורים: 0"
        android:textSize="14sp"
        android:fontFamily="@font/miriwinwebfont"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_my_appointments"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:text="אין תורים עדיין"
        android:textSize="18sp"
        android:fontFamily="@font/asakimboldwebfont"
        android:textColor="#888888"
        android:visibility="gone"/>

</LinearLayout>