<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".screens.Step2LaserActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/textView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:layout_marginBottom="80dp"
            android:fontFamily="@font/nootaj"
            android:text="איזורים ללייזר"
            android:textSize="37sp" />

        <TableLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp">

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <CheckBox
                    android:id="@+id/btn_yadaeem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:layout_marginEnd="90dp"
                    android:layout_marginBottom="40dp"
                    android:fontFamily="@font/asakimboldwebfont"
                    android:textSize="20sp"
                    android:text="ידיים" />

                <CheckBox
                    android:id="@+id/btn_raglaeem"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:layout_marginEnd="20dp"
                    android:fontFamily="@font/asakimboldwebfont"
                    android:textSize="20sp"
                    android:text="רגליים" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <CheckBox
                    android:id="@+id/btn_betshehi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:layout_marginEnd="90dp"
                    android:layout_marginBottom="40dp"
                    android:fontFamily="@font/asakimboldwebfont"
                    android:textSize="20sp"
                    android:text="בת שחי" />

                <CheckBox
                    android:id="@+id/btn_mefsaot"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:layout_marginEnd="100dp"
                    android:fontFamily="@font/asakimboldwebfont"
                    android:textSize="20sp"
                    android:text="מפשעה" />
            </TableRow>

            <TableRow
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <CheckBox
                    android:id="@+id/btn_beten"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:fontFamily="@font/asakimboldwebfont"
                    android:layout_marginEnd="90dp"
                    android:textSize="20sp"
                    android:text="בטן" />

                <CheckBox
                    android:id="@+id/btn_gav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layoutDirection="rtl"
                    android:fontFamily="@font/asakimboldwebfont"
                    android:layout_marginEnd="100dp"
                    android:textSize="20sp"
                    android:text="גב" />
            </TableRow>
        </TableLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="140dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btngoback"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#ff0084"
                android:fontFamily="@font/asakimboldwebfont"
                android:text="חזור" />

            <Button
                android:id="@+id/btncontinue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:backgroundTint="#ff0084"
                android:layout_marginStart="16dp"
                android:fontFamily="@font/asakimboldwebfont"
                android:text="המשך" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="46dp"
            android:background="#ff0084" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>