<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="?attr/colorSurface"
    android:backgroundTint="@color/white"
    android:gravity="center_horizontal">

    <!-- אייקון V ירוק -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="16dp"
        android:src="@drawable/ic_check_circle"
        android:tint="@color/green_500"
        android:contentDescription="תור נקבע" />

    <!-- כותרת -->
    <TextView
        android:id="@+id/textView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="40dp"
        android:fontFamily="@font/nootaj"
        android:gravity="center"
        android:text="התור נקבע בהצלחה!"
        android:textSize="30sp" />

    <!-- כרטיס פרטי התור -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- שירות -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שירות"
                android:fontFamily="@font/asakimboldwebfont"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:fontFamily="@font/asakimboldwebfont"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="16dp"/>

            <!-- אופציות -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="אופציות"
                android:fontFamily="@font/asakimboldwebfont"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_options"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:fontFamily="@font/asakimboldwebfont"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="16dp"/>

            <!-- תאריך -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="תאריך"
                android:textSize="13sp"
                android:fontFamily="@font/asakimboldwebfont"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_date"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:fontFamily="@font/asakimboldwebfont"
                android:textColor="?attr/colorOnSurface"
                android:layout_marginBottom="16dp"/>

            <!-- שעה -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="שעה"
                android:fontFamily="@font/asakimboldwebfont"
                android:textSize="13sp"
                android:textColor="#888888"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:fontFamily="@font/asakimboldwebfont"
                android:textColor="?attr/colorOnSurface"/>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- כפתור חזרה לדף הבית -->
    <Button
        android:id="@+id/btn_home"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="#ff0084"
        android:fontFamily="@font/asakimboldwebfont"
        android:text="חזרה לדף הבית" />

    <!-- פס ורוד מתחת לכפתורים -->
    <View
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="160dp"
        android:background="#ff0084" />

</LinearLayout>